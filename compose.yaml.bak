# compose.yaml
services:
  ollama:
    image: docker.io/ollama/ollama
    container_name: ollama
    volumes:
      - ollama_data:/root/.ollama
    ports:
      - "11434:11434"
    # devices:
    #   - nvidia.com/gpu=all

  airtool:
    image: ghcr.io/cmu-sei/airtool-dev:v1.3.0
    container_name: airtool
    stdin_open: true    # -i
    tty: true           # -t
    volumes:
      - .:/workspace
    ports:
      - "4173:4173"
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
    depends_on:
      - ollama

volumes:
  ollama_data:
